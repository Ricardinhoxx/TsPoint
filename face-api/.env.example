DATABASE_URL=postgres://app:app@localhost:5432/digitaliza
INTERNAL_SECRET=change-me-too

# Modo fake: gera embeddings determinísticos por hash da imagem (somente para testar pipeline).
# Para reconhecimento real, deixe 0 e instale as dependências (insightface/onnxruntime/opencv).
FACE_FAKE_MODE=0

# Modelo do InsightFace (CPU). "buffalo_l" é o padrão e retorna embeddings 512D.
FACE_MODEL=buffalo_l

# Tamanho de detecção (px). Maior = mais lento, geralmente 640 é ok.
FACE_DET_SIZE=640

# Threshold inicial (cosine similarity). Ajuste com seus dados.
FACE_THRESHOLD=0.42
