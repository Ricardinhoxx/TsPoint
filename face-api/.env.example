DATABASE_URL=postgres://app:app@localhost:5432/digitaliza
INTERNAL_SECRET=change-me-too

# Fake mode generates deterministic embeddings from the image hash.
# Use only for pipeline tests. Never use FACE_FAKE_MODE=1 in production.
FACE_FAKE_MODE=0

# InsightFace CPU model. buffalo_l is the default and returns 512D embeddings.
FACE_MODEL=buffalo_l

# Detection size in pixels. Higher values are slower; 640 is a good start.
FACE_DET_SIZE=640

# Initial cosine similarity threshold. Calibrate with real enrollment data.
FACE_THRESHOLD=0.42
