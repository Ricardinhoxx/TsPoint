DATABASE_URL=postgres://app:app@localhost:5432/digitaliza
AUTH_SECRET=change-me

# URL do Face API no Fly (ex: https://<app>.fly.dev)
FACE_API_URL=http://localhost:8080
FACE_API_SECRET=change-me-too

# Azure Entra ID (opcional)
# AZURE_ENTRA_TENANT_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
# AZURE_ENTRA_CLIENT_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# Supabase (recomendado para fluxo Azure já existente)
SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
SUPABASE_JWT_AUDIENCE=authenticated
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR_SUPABASE_ANON_KEY
