DATABASE_URL=postgres://app:app@localhost:5432/digitaliza
AUTH_SECRET=change-me

# Public app URL used by origin checks in production, for example:
# NEXT_PUBLIC_APP_URL=https://digitaliza-sodexo.vercel.app
# APP_URL=https://digitaliza-sodexo.vercel.app

# Face API URL. In production, use the Fly.io HTTPS URL.
FACE_API_URL=http://localhost:8080
FACE_API_SECRET=change-me-too

# Azure Entra ID (optional, legacy/direct token flow)
# AZURE_ENTRA_TENANT_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
# AZURE_ENTRA_CLIENT_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# Supabase Auth. Used for email/password sign up and login.
SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
SUPABASE_ANON_KEY=YOUR_SUPABASE_ANON_KEY
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR_SUPABASE_ANON_KEY

# Auto-provision creates the app supervisor row after a valid Supabase signup/login.
# OAUTH_AUTO_PROVISION_ENABLED=false
# OAUTH_AUTO_PROVISION_ALLOWED_DOMAIN=empresa.com
# Use "*" only for local/dev if any email should be accepted.
# OAUTH_AUTO_PROVISION_UNIDADE_ID=1
# OAUTH_AUTO_PROVISION_ROLE=SUPERVISOR
